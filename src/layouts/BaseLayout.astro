---
import '../styles/global.css';
import SiteHeader from '../components/navigation/SiteHeader.astro';
import SiteFooter from '../components/common/SiteFooter.astro';
import SEO from '../components/seo/SEO.astro';
import type { Lang } from '../i18n/ui';

interface Props {
  title: string;
  description?: string;
  lang: Lang;
  translationSlug?: string;
}

const { title, description, lang, translationSlug } = Astro.props;
---

<!DOCTYPE html>
<html lang={lang === 'ko' ? 'ko-KR' : 'en-US'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Inter:wght@400;500&family=Noto+Sans+KR:wght@300;400;500&family=Noto+Serif+KR:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <SEO title={title} description={description} lang={lang} translationSlug={translationSlug} />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body class="min-h-screen flex flex-col">
    <SiteHeader lang={lang} translationSlug={translationSlug} />
    <main class="flex-1">
      <slot />
    </main>
    <SiteFooter lang={lang} />
  </body>
</html>
